{
  "name": "elevatorbud",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev dev:convex --concurrency 20",
    "dev:admin": "concurrently \"npx convex dev\" \"pnpm --filter @elevatorbud/admin dev\"",
    "dev:client": "concurrently \"npx convex dev\" \"pnpm --filter @elevatorbud/client dev\"",
    "dev:landing": "concurrently \"npx convex dev\" \"pnpm --filter @elevatorbud/landing dev\"",
    "dev:convex": "npx convex dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck && tsc --noEmit -p convex/tsconfig.json"
  },
  "devDependencies": {
    "@clerk/backend": "^3.2.4",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "convex": "^1.34.1",
    "resend": "^6.10.0",
    "svix": "^1.89.0",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "dependencies": {
    "@convex-dev/aggregate": "^0.2.1",
    "convex-helpers": "^0.1.114"
  }
}
