{
  "name": "elevatorbud",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev dev:convex --concurrency 20",
    "dev:convex": "npx convex dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck && tsc --noEmit -p convex/tsconfig.json"
  },
  "devDependencies": {
    "convex": "^1.34.1",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
