# Local development (Docker Compose Postgres)
DATABASE_URL=postgresql://elevatorbud:elevatorbud@localhost:5432/elevatorbud

# Clerk
CLERK_SECRET_KEY=sk_test_...
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ---------------------------------------------------------------------------
# Migration target env files (gitignored):
#
#   .env.development   — used by `pnpm db:migrate:dev` / `db:reset:dev`
#   .env.production    — used by `pnpm db:migrate:prod` / `db:reset:prod`
#
# Each must contain a DATABASE_URL pointing at the corresponding Neon branch.
# Example:
#
#   # .env.development
#   DATABASE_URL=postgresql://user:pass@ep-<dev-branch>-pooler.<region>.aws.neon.tech/neondb?sslmode=require
#
#   # .env.production
#   DATABASE_URL=postgresql://user:pass@ep-<prod-branch>-pooler.<region>.aws.neon.tech/neondb?sslmode=require
# ---------------------------------------------------------------------------
